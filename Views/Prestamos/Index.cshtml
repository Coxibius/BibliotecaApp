@model IEnumerable<BibliotecaApp.Models.Prestamo>

@{
    ViewData["Title"] = "Préstamos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Préstamos</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Préstamo
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mt-3 align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Libro)</th>
                    <th>@Html.DisplayNameFor(model => model.Estudiante)</th>
                    <th>@Html.DisplayNameFor(model => model.FechaPrestamo)</th>
                    <th>@Html.DisplayNameFor(model => model.FechaDevolucion)</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model) {
                <tr>
                    <td>@(item.Libro != null ? item.Libro.Titulo : "Desconocido")</td>
                    <td>@(item.Estudiante != null ? item.Estudiante.Nombre : "Desconocido")</td>
                    <td>@item.FechaPrestamo.ToShortDateString()</td>
                    <td>@(item.FechaDevolucion.HasValue ? item.FechaDevolucion.Value.ToShortDateString() : "-")</td>
                    <td>
                        @if (item.FechaDevolucion == null)
                        {
                            <span class="badge bg-warning text-dark">Pendiente</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Devuelto</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            @if (item.FechaDevolucion == null)
                            {
                                <form asp-action="Devolver" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success me-1">
                                        <i class="bi bi-box-arrow-in-down"></i> Devolver
                                    </button>
                                </form>
                            }
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                        </div>
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
</div>
