@model IEnumerable<BibliotecaApp.Models.Libro>

@{
    ViewData["Title"] = "Catálogo de Libros";
}

<div class="container py-4">

    <!-- Encabezado -->
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-book-half fs-2 text-primary me-3"></i>
        <div>
            <h1 class="mb-0 fw-bold">Catálogo de Libros Disponibles</h1>
            <p class="text-muted mb-0">Libros que puedes solicitar en préstamo</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info d-flex align-items-center" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i>
            <span>No hay libros disponibles en este momento.</span>
        </div>
    }
    else
    {
        <!-- Contador -->
        <p class="text-muted mb-3">
            <strong>@Model.Count()</strong> libro(s) disponible(s)
        </p>

        <!-- Tarjetas -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var libro in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-primary text-white py-2">
                            <i class="bi bi-bookmark-fill me-1"></i>
                            <small>Disponible</small>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title fw-semibold">@libro.Titulo</h5>
                            <p class="card-text text-muted mb-1">
                                <i class="bi bi-person me-1"></i>
                                @(libro.Autor?.Nombre ?? "Autor desconocido")
                            </p>
                            <p class="card-text">
                                <i class="bi bi-calendar3 me-1"></i>
                                <small class="text-muted">Año: @libro.AnioPublicacion</small>
                            </p>
                            @if (!string.IsNullOrEmpty(libro.ISBN))
                            {
                                <p class="card-text">
                                    <small class="text-muted">ISBN: @libro.ISBN</small>
                                </p>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-top-0 pb-3">
                            <a asp-controller="Prestamos" asp-action="Create"
                               class="btn btn-sm btn-outline-primary w-100">
                                <i class="bi bi-plus-circle me-1"></i> Solicitar préstamo
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
