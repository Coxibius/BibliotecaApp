@model BibliotecaApp.Models.Autor

@{
    ViewData["Title"] = "Eliminar Autor";
}

<div class="container mt-4">
    <h2 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Eliminar Autor</h2>
    <h4>¿Estás seguro de que deseas eliminar este autor?</h4>
    <hr />
    
    <div class="card border-danger col-md-8 shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">@Html.DisplayNameFor(model => model.Nombre)</dt>
                <dd class="col-sm-8 fw-bold">@Html.DisplayFor(model => model.Nombre)</dd>

                <dt class="col-sm-4 text-muted">@Html.DisplayNameFor(model => model.Nacionalidad)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Nacionalidad)</dd>

                <dt class="col-sm-4 text-muted">@Html.DisplayNameFor(model => model.FechaNacimiento)</dt>
                <dd class="col-sm-8">@Model.FechaNacimiento.ToShortDateString()</dd>
            </dl>
        </div>
        
        <div class="card-footer bg-light">
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger me-2">Eliminar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>
